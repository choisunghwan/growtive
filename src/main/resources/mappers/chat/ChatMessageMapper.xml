<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.growtive.chat.mapper.ChatMessageMapper">

    <resultMap id="ChatMessageMap" type="com.growtive.chat.model.ChatMessage">
        <id     property="msgId"     column="MSG_ID"/>
        <result property="roomId"    column="ROOM_ID"/>
        <result property="senderId"  column="SENDER_ID"/>
        <result property="content"   column="CONTENT"/>
        <result property="createdAt" column="CREATED_AT"/>
    </resultMap>

    <select id="selectMessagesByRoom" resultMap="ChatMessageMap">
        SELECT
            MSG_ID, ROOM_ID, SENDER_ID, CONTENT, CREATED_AT
        FROM CHAT_MESSAGE
        WHERE ROOM_ID = #{roomId}
        ORDER BY MSG_ID ASC
    </select>

    <insert id="insertMessage" parameterType="com.growtive.chat.model.ChatMessage">
        INSERT INTO CHAT_MESSAGE (
            ROOM_ID, SENDER_ID, CONTENT, CREATED_AT
        ) VALUES (
                     #{roomId}, #{senderId}, #{content}, NOW()
                 )
    </insert>

</mapper>
