<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- MyBatis Mapper: Document 관련 SQL 정의 -->
<mapper namespace="com.growtive.documind.mapper.DocumentMapper">

    <!-- DB 컬럼 → 자바 클래스 매핑 규칙 -->
    <resultMap id="DocumentMap" type="com.growtive.documind.model.Document">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="file_path" property="filePath"/>
        <result column="content" property="content"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 문서 INSERT -->
    <insert id="insert" parameterType="com.growtive.documind.model.Document"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO document(title, file_path, content)
        VALUES(#{title}, #{filePath}, #{content})
    </insert>

    <!-- 문서 단건 조회 -->
    <select id="findById" parameterType="long" resultMap="DocumentMap">
        SELECT id, title, file_path, content, created_at
        FROM document
        WHERE id = #{id}
    </select>

    <!-- 문서 전체 리스트 조회 -->
    <select id="findAll" resultMap="DocumentMap">
        SELECT id, title, file_path, content, created_at
        FROM document
        ORDER BY id DESC
    </select>

    <!-- 문서 삭제 -->
    <delete id="delete" parameterType="long">
        DELETE FROM document
        WHERE id = #{id}
    </delete>

</mapper>
