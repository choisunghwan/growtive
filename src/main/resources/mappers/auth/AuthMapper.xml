<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.growtive.auth.mapper.AuthMapper">

    <select id="findByUsername"
            resultType="com.growtive.user.model.User">

        SELECT *
        FROM users
        WHERE username = #{username}

    </select>

    <insert id="insertUser">

        INSERT INTO users (
            username,
            password,
            display_name,
            email
        )
        VALUES (
                   #{username},
                   #{password},
                   #{displayName},
                   #{email}
               )

    </insert>

</mapper>